# ============================================================
#  DEFENDO.AR — Variables de entorno
#  Copiá este archivo como .env y completá los valores
#  NUNCA subas el archivo .env a Git o a un repositorio público
# ============================================================

# API Key de Anthropic (Claude)
# Obtenela en: https://console.anthropic.com/settings/keys
CLAUDE_API_KEY=sk-ant-PEGA-TU-CLAVE-AQUI

# Puerto del servidor (opcional, por defecto 3000)
PORT=3000

# Dominio permitido para CORS (en producción, usá tu dominio real)
# Ejemplo: ALLOWED_ORIGIN=https://defendo.ar
ALLOWED_ORIGIN=*
